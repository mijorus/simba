<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="Preferences" parent="GtkBox">
    <property name="hexpand">true</property>
    <property name="orientation">1</property>
    <child>
      <object class="AdwPreferencesPage">
        <child>
          <object class="AdwPreferencesGroup">
            <child type="header-suffix">
              <object class="GtkButton" id="save_button">
                <property name="label" translatable="yes">Save</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Workgroup</property>
            <property name="description" translatable="yes">This setting controls what workgroup your server will appear to be in; changing it from the default value "WORKGROUP" might impact the ability to connect to this computer.</property>
            <child>
              <object class="AdwEntryRow" id="workgroup_row">
                <property name="title">Workgroup</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">NetBIOS name</property>
            <property name="description" translatable="yes">This sets the name of the current machine; usually you can access this machine by its local IP address or the NetBIOS name.</property>
            <child>
              <object class="AdwEntryRow" id="netbios_row">
                <property name="title">NetBIOS name</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">User shares</property>
            <property name="description" translatable="yes">Allow specific users to create and manage their own shared folders; this enables integrations with some file managers like Thunar or Dolphin</property>
            <child>
              <object class="AdwSwitchRow" id="usershare_enabled">
                <property name="title" translatable="true">Enable user shares</property>
                <property name="subtitle" translatable="true">You can manage which users that can set their own shares in the "Users" tab</property>
              </object>
            </child>
            <child>
              <object class="AdwSpinRow" id="usershare_max_shares_row">
                <property name="title" translatable="true">Max number of shares per-user</property>
                <property name="adjustment">
                  <object class="GtkAdjustment">
                    <property name="lower">1</property>
                    <property name="upper">10</property>
                    <property name="step-increment">1</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Security</property>
            <child>
              <object class="AdwSwitchRow" id="allow_only_toggle">
                <property name="sensitive">false</property>
                <property name="title" translatable="true">Restrict access to specific networks.</property>
              </object>
            </child>
            <child>
              <object class="AdwExpanderRow" id="allow_networks">
                <property name="title" translatable="true">Allowed networks</property>
                <property name="sensitive">false</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Debugging</property>
            <child>
              <object class="AdwEntryRow" id="logfile_row">
                <property name="title">Log file location</property>
                <property name="editable">0</property>
                <property name="sensitive">0</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>