<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="PrintersWidget" parent="GtkBox">
    <property name="hexpand">true</property>
    <property name="orientation">1</property>
    <child>
      <object class="AdwBanner" id="auth_banner">
        <property name="title" translatable="yes">Authentication required to manage allowed users</property>
        <property name="revealed">false</property>
        <property name="button-label" translatable="yes">Unlock</property>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesPage">
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Print service</property>
            <child>
              <object class="AdwSwitchRow" id="enable_print_service">
                <property name="title" translatable="yes">Enable print service</property>
                <property name="subtitle" translatable="yes">Share printers connected to this computer over the network</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="yes">Access control</property>
            <child>
              <object class="AdwSwitchRow" id="restrict_access">
                <property name="title" translatable="yes">Restrict access</property>
                <property name="subtitle" translatable="yes">Only allow specific users to use the print service</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup" id="allowed_users_group">
            <property name="title" translatable="yes">Allowed users</property>
            <property name="visible">false</property>
            <child type="header-suffix">
              <object class="GtkBox">
                <property name="spacing">6</property>
                <property name="valign">center</property>
                <child>
                  <object class="GtkButton" id="add_user_button">
                    <property name="icon_name">sb-plus</property>
                    <property name="label" translatable="yes">Add user</property>
                    <property name="sensitive">false</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
