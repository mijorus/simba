<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
	<id>it.mijorus.simba.desktop</id>
    <name>Simba</name>
    <summary>A Samba manager</summary>
    <url type="donation">https://ko-fi.com/mijorus</url>
    <url type="homepage">https://github.com/mijorus/simba</url>
    <url type="bugtracker">https://github.com/mijorus/simba/issues</url>
	<url type="vcs-browser">https://github.com/mijorus/simba</url>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>
    <developer id="mijorus.it">
      <name translatable="no">Lorenzo Paderi</name>
    </developer>
    <description>
        <p>
			Note: this application is still in active development.
			Simba is a simple UI to manage your local Samba server.
		</p>
    </description>
    <releases>
        <release type="stable" version="0.2.0" date="2026-04-19:00:00Z">
            <description>
                <p>- New icon!</p>
                <p>- Added about section</p>
            </description>
        </release>
        <release type="stable" version="0.1.0" date="2026-04-13:00:00Z">
            <description>
                <p>- First release</p>
            </description>
        </release>
    </releases>
    <screenshots>
        <screenshot type="default">
            <caption>Sharing folders</caption>
            <image type="source">
                https://raw.githubusercontent.com/mijorus/simba/master/docs/screen1.png</image>
        </screenshot>
        <screenshot>
            <caption>Preferences</caption>
            <image type="source">
                https://raw.githubusercontent.com/mijorus/simba/master/docs/screen2.png</image>
        </screenshot>
        <screenshot>
            <caption>User management</caption>
            <image type="source">
                https://raw.githubusercontent.com/mijorus/simba/master/docs/screen3.png</image>
        </screenshot>
    </screenshots>
    <content_rating type="oars-1.0" />
</component>
